{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=license_mgmt;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Secret": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "LicenseManagement",
    "Audience": "LicenseManagement"
  },
  "Security": {
    "MasterEncryptionKey": "CHANGE_THIS_MASTER_KEY_FOR_LICENSE_ENCRYPTION"
  },
  "App": {
    "BaseUrl": "http://localhost:5000",
    "FrontendUrl": "http://localhost:3000"
  },
  "Payment": {
    "MoMo": {
      "PartnerCode": "MOMO_PARTNER_CODE",
      "AccessKey": "MOMO_ACCESS_KEY",
      "SecretKey": "MOMO_SECRET_KEY",
      "Endpoint": "https://test-payment.momo.vn/v2/gateway/api/create"
    },
    "VnPay": {
      "TmnCode": "VNPAY_TMN_CODE",
      "HashSecret": "VNPAY_HASH_SECRET",
      "PaymentUrl": "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
    },
    "ZaloPay": {
      "AppId": 0,
      "Key1": "ZALOPAY_KEY1",
      "Key2": "ZALOPAY_KEY2",
      "Endpoint": "https://sb-openapi.zalopay.vn/v2/create"
    }
  },
  "Email": {
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "Username": "",
      "Password": "",
      "FromEmail": "noreply@licensemanagement.com",
      "FromName": "License Management",
      "UseSsl": true
    }
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "post:/api/v1/auth/*",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "post:/api/v1/licenses/activate",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "post:/api/v1/licenses/heartbeat",
        "Period": "1m",
        "Limit": 20
      },
      {
        "Endpoint": "post:/api/v1/payments/topup",
        "Period": "1m",
        "Limit": 5
      }
    ]
  },
  "Cors": {
    "Origins": ["http://localhost:3000"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
